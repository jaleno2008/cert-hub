{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@schemas/*": [
        "packages/schemas/*"
      ],
      "@utils/*": [
        "packages/utils/*"
      ]
    }
  }
}