{
  "name": "cert-hub",
  "private": true,
  "packageManager": "pnpm@9.6.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "echo \"(add eslint later)\"",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx scripts/seed.ts",
    "claude:sweep": "echo 'Repo-wide refactor? See docs/ROUTING.md'",
    "codex:feature": "echo 'Use GPT-5 Codex for feature tickets'"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "date-fns": "^3.6.0",
    "zod": "^3.23.8"
  }
}