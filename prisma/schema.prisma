generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Tester {
  id         String             @id @default(cuid())
  email      String             @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  assessment AssessmentResult?
}

model AssessmentResult {
  id               String   @id @default(cuid())
  testerId         String   @unique
  tester           Tester   @relation(fields: [testerId], references: [id], onDelete: Cascade)

  score            Int

  registered       Boolean  @default(false)
  ein              Boolean  @default(false)
  bank             Boolean  @default(false)
  insurance        Boolean  @default(false)
  financials       Boolean  @default(false)
  capability       Boolean  @default(false)
  pastPerformance  Boolean  @default(false)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}